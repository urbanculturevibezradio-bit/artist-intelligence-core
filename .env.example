# ============================================================
# .env.example — Environment variables for hum-to-riddim pipeline
# Copy to .env.local and fill in your values
# ============================================================

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/artist-intelligence?retryWrites=true&w=majority

# Supabase (pgvector)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379
# For Upstash Redis on Vercel:
# REDIS_URL=rediss://:<password>@<hostname>:6380

# File storage
TEMP_UPLOAD_DIR=/tmp/artist-intelligence-uploads
PACKAGES_DIR=/tmp/artist-intelligence-packages

# DSP microservice (Python — librosa/essentia/aubio)
# DSP_SERVICE_URL=http://localhost:5001

# ML service (style classification model)
# ML_SERVICE_URL=http://localhost:5002

# OpenAI (Whisper API)
OPENAI_API_KEY=sk-...

# Next.js
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Vercel Blob Storage (for stem files in production)
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
